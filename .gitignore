# TradeBot .gitignore

# Environment
.env
.env.local
.env.production

# Keep .env.example tracked (it's the template reference)
!.env.example

# Log files
*.log
*.log.*
log.log
gateway.log
executions.log

# Coverage
.coverage
htmlcov/
.coverage.*

# Database
*.db
*.db-wal
*.db-shm

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
*.egg
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
