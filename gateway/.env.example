# ============================================================
# TradeBot Gateway Environment Variables
# ============================================================
# Copy this file to gateway/.env and fill in your values.
# NEVER commit .env to version control.
#
# The Gateway reads this file from gateway/.env (relative to
# the repo root). Run uvicorn from the repo root, NOT from
# inside gateway/:
#
#   uvicorn gateway.app.main:app --host 0.0.0.0 --port 9000
#
# ============================================================

# ---------- Networking ----------
# Host to bind the Gateway HTTP server to.
# 0.0.0.0 = all interfaces (reachable from LAN/WSL)
GATEWAY_HOST=0.0.0.0
# Port to listen on (default: 9000)
GATEWAY_PORT=9000

# ---------- Authentication ----------
# Shared HMAC secret — must match GATEWAY_HMAC_SECRET in the
# Hub's .env file. Generate with: openssl rand -hex 32
GATEWAY_HMAC_SECRET=change-me-to-a-random-64-char-string

# ---------- MT5 Connection ----------
# Your Exness (or broker) demo/live account number
MT5_ACCOUNT=12345678
# Your MT5 trading password (NOT your Exness personal area password)
MT5_PASSWORD=
# Your broker's MT5 server name (e.g. Exness-MT5Trial9)
# Find it in MT5 Desktop: File → Login to Trade Account → Server
MT5_SERVER=
# Full path to MT5 terminal executable (optional — leave empty for
# auto-detection. Useful if auto-detect fails with IPC timeout).
# Example: C:\Program Files\MetaTrader 5 EXNESS\terminal64.exe
MT5_TERMINAL_PATH=

# ---------- Mock Mode ----------
# Set to False when you have real MT5 running on Windows.
# Set to True to use the mock backend (development/Linux, no broker needed).
# When True, HMAC verification is also skipped.
MT5_MOCK=True

# ---------- Risk Limits ----------
# Maximum lot size per single trade
RISK_MAX_SINGLE_LOT=10.0
# Maximum total volume across all trades in a day
RISK_MAX_DAILY_VOLUME=50.0
# Maximum number of simultaneously open positions
RISK_MAX_OPEN_POSITIONS=10
# Maximum account exposure percentage (positions / balance)
RISK_MAX_EXPOSURE_PCT=30.0
# Comma-separated list of allowed trading symbols
RISK_ALLOWED_SYMBOLS=EURUSD,GBPUSD,USDJPY,XAUUSD

# ---------- Logging ----------
LOG_LEVEL=INFO
