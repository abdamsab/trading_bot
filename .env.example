# ============================================================
# TradeBot Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Provided providers (set via LLM_PROVIDER):
#   openai     — OpenAI (GPT-4o, GPT-4o-mini, o1, o3, etc.)
#   openrouter — OpenRouter (unified access to 200+ models)
#   anthropic  — Anthropic (Claude Sonnet 4, Haiku 3.5, etc.)
#   ollama     — Self-hosted local models (default: http://localhost:11434/v1)
#   vllm       — Self-hosted vLLM (default: http://localhost:8000/v1)
#   groq       — Groq (ultra-fast inference)
#   together   — Together AI
#   deepseek   — DeepSeek
#   azure      — Azure OpenAI (requires LLM_BASE_URL)
#   gemini     — Google Gemini (Gemini 2.0 Flash, Pro, etc.)
#   custom:<name> — Any OpenAI-compatible endpoint you host yourself
#                    (REQUIRES LLM_BASE_URL to be set)
#
# Examples:
#   LLM_PROVIDER=openai
#   LLM_PROVIDER=anthropic
#   LLM_PROVIDER=ollama
#   LLM_PROVIDER=custom:my-local-llama  (with LLM_BASE_URL=http://192.168.1.50:8000/v1)

# ---------- Telegram ----------
TELEGRAM_BOT_TOKEN=your_bot_token_here
USER_TELEGRAM_ID=123456789

# ---------- LLM Provider ----------
# Choose your provider: openai, openrouter, anthropic, ollama, vllm,
# groq, together, deepseek, azure, gemini, or custom:<name>
LLM_PROVIDER=openai
LLM_API_KEY=«your_api_key_here»
# Override model (empty = provider default, e.g. gpt-4o-mini for OpenAI)
LLM_MODEL=
# Override base URL (required for custom:<name> and azure providers)
# Self-hosted example: http://192.168.1.50:8000/v1
LLM_BASE_URL=

# ---------- Database ----------
# Dev (SQLite):  sqlite+aiosqlite:///./tradebot.db
# Prod (PostgreSQL): postgresql+asyncpg://user:pass@localhost:5432/tradebot
DATABASE_URL=sqlite+aiosqlite:///./tradebot.db

# ---------- Gateway (MT5) ----------
GATEWAY_BASE_URL=http://localhost:9000
GATEWAY_HMAC_SECRET=change-me-to-a-random-64-char-string

# ---------- Rate Limits ----------
PROPOSAL_EXPIRY_SECONDS=300
RATE_LIMIT_SYMBOL_COOLDOWN_MINUTES=30
RATE_LIMIT_GLOBAL_MAX_PER_HOUR=5
RATE_LIMIT_CONFIDENCE_FLOOR=0.60
RATE_LIMIT_MAX_PENDING=3
RATE_LIMIT_DAILY_CAP=20

# ---------- Gateway Risk Limits (mirrored in gateway/.env) ----------
RISK_MAX_SINGLE_LOT=10.0
RISK_MAX_DAILY_VOLUME=50.0
RISK_MAX_OPEN_POSITIONS=10
RISK_MAX_EXPOSURE_PCT=30.0
RISK_ALLOWED_SYMBOLS=EURUSD,GBPUSD,USDJPY,XAUUSD

# ---------- Logging ----------
LOG_LEVEL=INFO

# ---------- Market Data ----------
# Provider: "twelve_data" (default), "alpha_vantage", or empty to disable
MARKET_DATA_PROVIDER=twelve_data
# Free API key from https://twelvedata.com/apikey
MARKET_DATA_API_KEY=

# ---------- News ----------
# Fetch forex headlines from RSS feeds on /proposal
NEWS_ENABLED=True
NEWS_MAX_HEADLINES=5

# ---------- Scheduled Scanning ----------
# Auto-generate proposals on a timer (requires APScheduler)
SCAN_ENABLED=False
# Cron expression: minute hour day-of-month month day-of-week
# Standard: "0 */4 * * *" = every 4 hours
SCAN_SCHEDULE=0 */4 * * *
# Symbols to scan (comma-sep). Empty = use RISK_ALLOWED_SYMBOLS
SCAN_SYMBOLS=
